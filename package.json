{
	"name": "kickstart-sveltekit",
	"version": "0.1.0",
	"type": "module",
	"private": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/contentstack/kickstart-sveltekit"
	},
	"description": "Contentstack Kickstarts are the minimum amount of code needed to connect to Contentstack.",
	"author": "Tim Benniks <tim.benniks@contentstack.com>",
	"homepage": "https://contentstack.com",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.65.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.3.1",
		"@types/eslint": "^9.6.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^7.3.5"
	},
	"dependencies": {
		"@contentstack/delivery-sdk": "^5.2.1",
		"@contentstack/live-preview-utils": "^4.4.4",
		"@contentstack/utils": "^1.9.1"
	},
	"overrides": {
		"axios": "^1.18.0",
		"dompurify": "^3.4.11",
		"follow-redirects": "^1.16.0",
		"lodash": "^4.18.1",
		"lodash-es": "^4.18.1",
		"uuid": "^14.0.0"
	},
	"optionalDependencies": {
		"lightningcss-linux-x64-gnu": "^1.32.0"
	}
}